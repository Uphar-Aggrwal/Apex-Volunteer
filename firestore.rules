rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Zones — readable by all clients (real-time onSnapshot).
    // Writes are performed server-side via Firebase Admin SDK in Netlify Functions,
    // which bypass these rules entirely, so client write is locked.
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if false;
    }

    // Alerts — read-only from clients
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if false;
    }

    // Translations — read-only from clients
    match /translations/{translationId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
