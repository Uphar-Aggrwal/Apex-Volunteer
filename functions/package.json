{
  "name": "volunteer-ai-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Apex Volunteer",
  "main": "src/index.js",
  "engines": { "node": "18" },
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.4.0",
    "@google/generative-ai": "^0.24.1"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": { "^.+\\.js$": "babel-jest" },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": { "lines": 85, "functions": 85, "statements": 85 }
    }
  }
}
